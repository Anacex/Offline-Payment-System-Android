# Copy to ".env" and fill in values (never commit .env).
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/offlinepay
SECRET_KEY=replace-with-long-random-string-min-32-chars

# Production: false — hides otp_demo in API responses; OTP codes only in logs when DEBUG=true
DEBUG=false

# -----------------------------------------------------------------------------
# OTP (signup / login step-2 / wallet create / top-up)
# -----------------------------------------------------------------------------
# Dedicated secret for OTP code hashing (do not reuse SECRET_KEY alone in production).
# Generate e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
OTP_PEPPER=

# Strongly recommended: OTP challenges survive process restarts and scale across workers.
# Examples:
#   redis://localhost:6379/0
#   rediss://default:PASSWORD@REGION.upstash.io:6379
REDIS_URL=

# -----------------------------------------------------------------------------
# Wallet private keys at rest (server-side legacy PEM; prefer device-bound keys in app)
# -----------------------------------------------------------------------------
# Option A — Fernet key (url-safe base64, 44 chars), generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WALLET_AT_REST_FERNET_KEY=

# Option B — KMS-wrapped 32-byte Fernet key material (standard Base64 of KMS ciphertext).
# Requires boto3 and IAM decrypt on the key. Leave empty if using WALLET_AT_REST_FERNET_KEY only.
AWS_KMS_CIPHERTEXT_BLOB_BASE64=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Google Play Integrity (optional server-side token decode for Android)
# -----------------------------------------------------------------------------
# Absolute or relative path to GCP service account JSON with Play Integrity API enabled.
# Leave empty to disable /api/v1/device/play-integrity/decode (returns configured=false).
PLAY_INTEGRITY_SERVICE_ACCOUNT_JSON=

# Must match the Android applicationId / package name.
PLAY_INTEGRITY_PACKAGE_NAME=com.offlinepayment

# -----------------------------------------------------------------------------
# Other (optional)
# -----------------------------------------------------------------------------
# CORS_ORIGINS=https://your-frontend.com,https://app.your-frontend.com
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=30
# REQUIRE_SSL=true
